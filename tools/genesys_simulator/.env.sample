# Genesys Simulator Configuration for ART Voice Agent Accelerator
# Copy this file to .env and update values

# ART backend WebSocket URL (Genesys AudioHook endpoint)
# Local development:
SIMULATOR_SERVER_URL=ws://localhost:8081/api/v1/genesys/stream

# Azure deployment (replace with your Container App URL):
# SIMULATOR_SERVER_URL=wss://<your-container-app>.azurecontainerapps.io/api/v1/genesys/stream

# Scenario/prompt name (maps to ART scenario if configured)
PROMPT_NAME=Banking

# Optional: Override session IDs (auto-generated if not set)
# SIMULATOR_ORG_ID=your-org-id
# SIMULATOR_CONV_ID=your-conversation-id
